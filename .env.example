# Copy to .env for local use.
# On Render: set these in the service Environment tab (Blueprint fills MySQL for you).

APP_NAME=GoldWitch.com
APP_ABBREVIATION=GoldWitch
# Leave blank on Render — start.js uses RENDER_EXTERNAL_URL automatically
APP_URL=https://your-app.onrender.com

# Render/Railway inject PORT. APP_PORT is local only.
APP_PORT=3000
APP_SECURE=false

# development|production
APP_ENV=production

SESSION_SECRET=change-me-to-a-long-random-string

# Optional — visitor geo. Leave blank to skip (site still works).
IPINFO_API_TOKEN=

# Database — local OR Render MySQL private service / Railway MySQL
# Render Blueprint sets MYSQLHOST / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE / MYSQLPORT
# You can also paste MYSQL_URL / DATABASE_URL and leave the DB_* blank.
DB_DATABASE=vgowitch
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=casino
DB_PASSWORD=

# Optional OAuth / mail / payments
STEAM_GROUP_URL=
TWITTER_PAGE_URL=
DISCORD_SERVER_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=/auth/discord/callback

RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_PUBLIC_KEY=

DRAKON_AGENT_CODE=
DRAKON_AGENT_TOKEN=
DRAKON_AGENT_SECRET_KEY=
DRAKON_AGENT_CURRENCY=USD
DRAKON_LANGUAGE=en

# Comma-separated emails that get owner rank + admin panel access on boot
ADMIN_EMAILS=nbtnateyt@gmail.com,nbtrobinson@gmail.com

# Casino catalog
# all = every provider; us|ohio = US-friendly providers only
CASINO_MARKET=all
# Hide demo-only games
CASINO_REAL_MONEY_ONLY=false
# false = show every game from allowed providers
CASINO_ONE_PER_PROVIDER=false
# Keep only these Drakon provider codes (all games from each)
CASINO_ALLOWED_PROVIDERS=100hp,iconix,jacks,7-mojos,7mojos,7-mojos-slots,7mojos-slots,abracadabra,airdice,avatarux,amigogaming,bwgaming,bgaming,bgamingP,expanse-studios,funkygames,pgsoft,shadylady,wickedgames,mascot,pigaboom,caletagaming,onegame,imagine live,imagineliveLS,imagineliveHS,eezecasino,vivo,galaxsys,galaxsysP

NOWPAYMENTS_API_KEY=
NOWPAYMENTS_PUBLIC_KEY=
NOWPAYMENTS_CALLBACK_URL=/nowpayments/callback

# Crypto hash deposits (admin-approved). Defaults are set in config if env empty.
CRYPTO_HASH_DEPOSITS=true
CRYPTO_HASH_MIN_CONFIRMATIONS=1
CRYPTO_WALLET_BTC=bc1qvykus2xjawptxwz7qp0mwn5zxdetvzydv40eml
