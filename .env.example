# Copy to .env for local use.
# On Render: set these in the service Environment tab (Blueprint fills MySQL for you).

APP_NAME=GoldWitch.com
APP_ABBREVIATION=GoldWitch
# Leave blank on Render — start.js uses RENDER_EXTERNAL_URL automatically
APP_URL=https://your-app.onrender.com

# Render/Railway inject PORT. APP_PORT is local only.
APP_PORT=3000
APP_SECURE=false

# development|production
APP_ENV=production

SESSION_SECRET=change-me-to-a-long-random-string

# Database — local OR Render MySQL private service / Railway MySQL
# Render Blueprint sets MYSQLHOST / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE / MYSQLPORT
# You can also paste MYSQL_URL / DATABASE_URL and leave the DB_* blank.
DB_DATABASE=vgowitch
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=casino
DB_PASSWORD=

# Optional OAuth / mail / payments
STEAM_GROUP_URL=
TWITTER_PAGE_URL=
DISCORD_SERVER_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=/auth/discord/callback

RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_PUBLIC_KEY=

DRAKON_AGENT_CODE=
DRAKON_AGENT_TOKEN=
DRAKON_AGENT_SECRET_KEY=
DRAKON_AGENT_CURRENCY=USD
DRAKON_LANGUAGE=en

NOWPAYMENTS_API_KEY=
NOWPAYMENTS_PUBLIC_KEY=
NOWPAYMENTS_CALLBACK_URL=/nowpayments/callback

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
STRIPE_CURRENCY=usd
CASH_TEST_MODE=false

PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_CALLBACK_URL=/admin/paypal/callback
PAYPAL_WEBHOOK_ID=
