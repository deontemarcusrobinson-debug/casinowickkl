<div class="chat-message flex flex-col gap-2 relative p-2" data-message="<%= id %>">
    <div class="flex flex-row items-center gap-1 relative w-full pl-1">
        <img class="size-10 rounded-full" src="/img/avatar.jpg">

        <div class="chat-message-header flex flex-col justify-center gap-1">
            <div class="chat-message-name chat-link-system truncate">System</div>

            <div class="chat-message-time"><%= time %></div>
        </div>
    </div>

    <div class="chat-message-content bg-card p-2 rounded-2 chat-link-system"><%= message %></div>
</div>