<div class="flex flex-1 flex-col gap-4">
<div class="flex flex-1 flex-col gap-6">
        <%- include('./components/tabsMenu.ejs', {
            type: 'top',
            items: [
                {
                    active: false,
                    label: 'Lobby',
                    href: '/casino/lobby'
                },
                {
                    active: false,
                    label: 'Slots',
                    href: '/casino/slots'
                },
                {
                    active: false,
                    label: 'Live Games',
                    href: '/casino/live'
                },
                {
                    active: false,
                    label: 'Recent Games',
                    href: '/casino/recent'
                },
                {
                    active: false,
                    label: 'Favorites',
                    href: '/casino/favorites'
                },
                {
                    active: true,
                    label: 'Providers',
                    href: '/casino/providers'
                }
            ]
        }); %>

        <div class="flex flex-1 flex-col gap-4">
            <div class="flex flex-row max-md:flex-col gap-1 max-md:gap-4">
                <%- include('./components/inputs/inputGroup.ejs', {
                    type: 'text',
                    label: 'Search Game',
                    id: 'casino_providers_provider_games_search'
                }); %>

                <div class="flex flex-row gap-1">
                    <%- include('./components/inputs/selectField.ejs', {
                        type: 'bottom',
                        label: 'Order by',
                        id: 'casino_providers_provider_games_order',
                        items: [
                            { name: 'Popularity', value: 0 },
                            { name: 'Amount Won', value: 1 },
                            { name: 'Name A-Z', value: 2 },
                            { name: 'Name Z-A', value: 3 }
                        ]
                    }); %>
                </div>
            </div>

            <div class="flex flex-col gap-2 items-start py-2">
                <div class="flex flex-row items-center gap-2">
                    <img class="h-4" src="<%= response.casino.provider.image %>">

                    <span class="text-lg font-bold"><%= response.casino.provider.name %></span>
                </div>

                <div class="text-sm text-muted-foreground"><%= response.casino.provider.count %> games from <%= response.casino.provider.name %></div>
            </div>

            <div class="flex flex-col flex-1 gap-2">
                <div class="casino-games flex-1 h-full" id="casino_providers_provider_games">
                    <% if(response.casino.provider.games.list.length > 0){ %>
                        <% response.casino.provider.games.list.forEach(function(item){ %>
                            <%- include('./components/casinoGame.ejs', item); %>
                        <% }); %>
                    <% } else { %>
                        <%- include('./components/emptyState.ejs', {
                            title: 'No games found'
                        }); %>
                    <% } %>
                </div>

                <div class="flex items-center justify-center bg-secondary p-2 border-t-2 border-card">
                    <%- include('./components/pageStepper.ejs', {
                        id: 'pagination_casino_providers_provider_games',
                        page: response.casino.provider.games.page,
                        pages: response.casino.provider.games.pages
                    }); %>
                </div>
            </div>
        </div>
    </div>
</div>