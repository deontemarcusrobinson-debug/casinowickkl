<div class="flex flex-col items-center gap-4">
	<div class="flex flex-row justify-start w-full">
		<a href="/deposit">
            <button class="button button-hover button-accent shadow-2 flex flex-row gap-2 items-center justify-center">
                <%- include('./components/icon.ejs', {
                    icon: 'undo',
                    className: 'size-3.5'
                }); %>

                <span>Back to Options</span>
            </button>
        </a>
	</div>

	<div class="crypto-panel flex flex-col gap-2 w-8/12 max-md:w-full" id="crypto_deposit_panel">
		<div class="flex flex-col gap-1">
			<div class="text-xl font-bold">Deposit with <%= response.deposit.name %></div>

			<div class="text-xs text-muted-foreground">Enter the amount, click Deposit, then send the exact crypto amount to our wallet and submit your TX hash for approval.</div>
		</div>

        <div class="submit flex flex-col gap-2">
            <div class="flex flex-col gap-2 bg-card bg-opacity-50 text-left rounded-2 border-2 border-secondary p-4">
                <div class="flex flex-col gap-4">
                    <div class="text-base font-bold"><%= response.deposit.name %> deposit amount</div>

                    <%- include('./components/inputs/inputGroup.ejs', {
                        type: 'text',
                        label: 'Amount ' + response.deposit.name,
                        labelIcon: include('./components/icon.ejs', {
                            icon: app.paths[2],
                            className: 'icon-color transition duration-200'
                        }),
                        id: 'crypto_deposit_value',
                        attributes: [
                            { name: 'data-conversion', value: 'to' },
                            { name: 'data-currency', value: app.paths[2] }
                        ],
                        errors: [ 'number' ]
                    }); %>
                </div>

                <div class="flex flex-col gap-4">
                    <div class="text-base font-bold">You receive (estimate)</div>

                    <div class="flex flex-row gap-2 items-center">
                        <%- include('./components/inputs/inputGroup.ejs', {
                            type: 'text',
                            label: 'Amount Coins',
                            labelIcon: include('./components/icon.ejs', {
                                icon: 'diamond',
                                className: 'text-primary transition duration-200'
                            }),
                            value: '20.00',
                            attributes: [
                                { name: 'data-conversion', value: 'from' },
                                { name: 'data-currency', value: app.paths[2] },
                                { name: 'data-amount', value: 'deposit_crypto' }
                            ],
                            errors: [ 'required', 'number', 'greater', 'lesser' ]
                        }); %>

                        <button type="button" class="button button-hover button-primary shadow-2 large" id="crypto_deposit" data-currency="<%= app.paths[2] %>">Deposit</button>
                    </div>

                    <div class="text-xs text-muted-foreground">After you click Deposit you will see the exact amount and wallet address to pay.</div>
                </div>
            </div>

            <div class="bg-card bg-opacity-50 text-left rounded-2 border-2 border-secondary p-4">
                <div class="text-base font-bold">Only deposit over the <%= response.deposit.network %> Network!</div>
            </div>
        </div>

        <div class="payment flex flex-col gap-2">
            <div class="bg-card bg-opacity-50 text-left rounded-2 border-2 border-secondary p-4">
                <div class="flex flex-row max-md:flex-col gap-2">
                    <div class="crypto-deposit-qrcode <%= app.paths[2] %>" id="crypto_deposit_qrcode"></div>

                    <div class="flex flex-col gap-4">
                        <div class="text-base font-bold">Send exactly <span class="text-primary"><span id="crypto_deposit_payment_value">0.00</span> <%= app.paths[2].toUpperCase() %></span> via <span class="text-primary"><%= response.deposit.network %></span> to:</div>

                        <div class="flex flex-row items-center gap-2">
                            <%- include('./components/inputs/inputGroup.ejs', {
                                type: 'text',
                                label: 'Wallet address',
                                id: 'crypto_deposit_payment_address',
                                value: response.deposit.address || ''
                            }); %>

                            <button type="button" class="button button-hover button-primary shadow-2 large" data-copy="input" data-input="#crypto_deposit_payment_address">Copy</button>
                        </div>

                        <div class="text-xs text-warning">Send the exact amount shown. Wrong network or wrong amount may delay or prevent crediting.</div>
                    </div>
                </div>
            </div>

            <div class="bg-card bg-opacity-50 flex flex-col gap-4 rounded-2 border-2 border-secondary p-4">
                <div class="flex flex-row justify-between items-center gap-2">
                    <div class="flex flex-col items-start gap-1">
                        <div class="text-muted-foreground font-bold">You receive (estimate):</div>
                        <div class="flex flex-row items-center justify-center gap-1">
                            <%- include('./components/icon.ejs', {
                                icon: 'diamond',
                                className: 'text-primary size-5'
                            }); %>
                            <span class="text-xl" id="crypto_deposit_payment_amount">0.00</span>
                        </div>
                    </div>
                    <button type="button" class="button button-hover button-accent shadow-2 large" id="crypto_deposit_back">Back</button>
                </div>

                <div class="flex flex-col gap-2">
                    <div class="text-base font-bold">After sending, paste your TX hash</div>
                    <input type="hidden" id="crypto_hash_currency" value="<%= app.paths[2] %>">
                    <%- include('./components/inputs/inputGroup.ejs', {
                        type: 'text',
                        label: 'Transaction hash / TXID',
                        id: 'crypto_hash_tx',
                        errors: [ 'required' ]
                    }); %>
                    <button type="button" class="button button-hover button-primary shadow-2 large" id="crypto_hash_submit">Submit TX hash for approval</button>
                </div>
            </div>

            <div class="bg-card bg-opacity-50 text-left rounded-2 border-2 border-secondary p-4">
                <div class="text-base font-bold">An admin will approve your deposit after the TX is verified on-chain.</div>
            </div>
        </div>

        <div class="flex flex-col items-center gap-1 w-full">
            <div class="text-xs text-muted-foreground">Your payment will be processed through <%= app.abbreviation %>.</div>
            <div class="text-xs text-muted-foreground">By purchasing coins on <%= app.abbreviation %>, I attest that I agree to the <a class="underline text-primary" href="/tos" target="_blank">Terms of Service</a> in full.</div>
        </div>
	</div>
</div>