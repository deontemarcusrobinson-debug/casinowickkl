                    <div class="font-bold text-xl">Count Manual Deposits</div>

                    <div class="flex flex-row gap-1">
                        <%- include('../components/inputs/selectField.ejs', {
                            type: 'bottom',
                            className: 'dashboard-graph',
                            items: [
                                { name: 'This Day', value: 'day' },
                                { name: 'This Week', value: 'week' },
                                { name: 'This Month', value: 'month' },
                                { name: 'This Year', value: 'year' }
                            ]
                        }); %>
                    </div>
                </div>

                <div class="size-full relative">
                    <div class="dashboard-loader hidden bg-card bg-opacity-50 flex justify-center items-center">
