<div class="flex flex-col gap-2">
	<div class="flex flex-row gap-2">
		<a href="/admin/dashboard/summary"><button class="button button-hover button-accent shadow-2">Summary</button></a>
		<a href="/admin/dashboard/games"><button class="button button-hover button-accent shadow-2">Games</button></a>
		<a href="/admin/dashboard/payments"><button class="button button-hover button-accent shadow-2">Payments</button></a>
	</div>

	<div class="flex flex-row gap-2">
