            <div class="dashboard-stats flex flex-col items-center justify-between bg-card bg-opacity-50 border-2 border-card px-2 rounded-1" data-stats="total_manual_deposits">
                <div class="text-primary flex items-center h-full text-2xl"><span class="stats">0.00</span></div>
                <div class="font-bold text-center w-full p-2 border-t-2 border-card">Total Manual Deposits</div>
            </div>

            <div class="dashboard-stats flex flex-col items-center justify-between bg-card bg-opacity-50 border-2 border-card px-2 rounded-1" data-stats="count_manual_deposits">
