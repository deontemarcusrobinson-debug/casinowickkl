<% if(page == 'admin') { %>
<div class="modal small locked <% if(!account.authorized.admin){ %>active<% } %>" id="modal_admin_authorize">
	<div class="modal-dialog flex justify-center items-center">
		<div class="modal-content rounded-2">
			<div class="modal-header flex items-center justify-between">
				<div class="modal-title">Verification Authentication Required</div>
				<div class="modal-close flex justify-center items-center rounded-1" data-modal="hide">
					<%- include('../components/icon.ejs', {
						icon: 'close',
						className: ' size-2'
					}); %>
				</div>
			</div>
			<div class="modal-body text-left">
				<div class="flex flex-col gap-2">
                    <div class="text-muted-foreground">To access the Admin page, we need to verify it's you.</div>

                    <div class="flex flex-row gap-1">
                        <a class="w-full" href="/authorize/admin?returnUrl=/<%= app.paths.join('/') %>"><button class="button button-hover button-primary shadow-2 w-full">Continue</button></a>
                        <a class="w-full" href="/"><button class="button button-hover button-accent shadow-2 w-full" data-modal="hide">Cancel</button></a>
                    </div>
			    </div>
			</div>
		</div>
	</div>
</div>
<% } %>

