					<div class="flex flex-col gap-2" id="fair_draw">
						<div class="text-xs w-full truncate"><span class="text-muted-foreground mr-1">Draw Public Seed:</span><span class="pointer" id="fair_draw_public_seed" data-copy="text" data-text="">-</span></div>
						<div class="text-xs w-full truncate"><span class="text-muted-foreground mr-1">Draw EOS block:</span><a id="fair_draw_block_link" href="" target="_black"><span id="fair_draw_block">-</span></a></div>
					</div>
				</div>
			</div>
			<div class="modal-footer text-center">
				<button type="button" class="button button-hover button-primary shadow-2" data-modal="hide">Close</button>
			</div>
		</div>
	</div>
</div>
<% } %>

