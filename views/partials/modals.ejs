<% if([
    'jackpot',
    'coinflip'
].includes(page)
) { %>
<div class="modal medium" id="modal_fair_round">
	<div class="modal-dialog flex justify-center items-center">
		<div class="modal-content rounded-2">
			<div class="modal-header flex items-center justify-between">
				<div class="modal-title">Round Results</div>
				<div class="modal-close flex justify-center items-center rounded-1" data-modal="hide">
					<%- include('../components/icon.ejs', {
						icon: 'close',
						className: ' size-2'
					}); %>
				</div>
			</div>
			<div class="modal-body text-left">
				<div class="flex flex-col gap-4">
					<div class="flex flex-col gap-2">
						<div class="text-xs w-full truncate"><span class="text-muted-foreground mr-1">Server Seed (hashed):</span><span class="pointer" id="fair_server_seed_hashed" data-copy="text" data-text="">-</span></div>
