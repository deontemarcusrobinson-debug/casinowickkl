<% if(page == 'affiliates') { %>
<div class="modal medium" id="modal_affiliates_tiers">
	<div class="modal-dialog flex justify-center items-center">
		<div class="modal-content rounded-2">
			<div class="modal-header flex items-center justify-between">
				<div class="modal-title">Affiliate Tiers</div>
				<div class="modal-close flex justify-center items-center rounded-1" data-modal="hide"></div>
			</div>
			<div class="modal-body text-left">
				<div class="affiliates-tiers flex flex-col gap-2 w-full overflow-auto">
					<% response.affiliates.tiers.forEach(function(item){ %>
						<div class="item <% if(!item.unlocked){ %>disabled<% } %> flex flex-col gap-4 bg-card rounded-2 border-2 border-accent p-4 w-full">
							<div class="flex flex-row items-center gap-2 border-b-2 border-accent pb-4">
								<img src="/img/affiliates/tier<%= item.tier %>.png">

								<div class="flex flex-row gap-2 items-center justify-between w-full">
									<div class="flex flex-col gap-2">
										<div class="capitalize text-lg font-bold"><%= item.name %> tier</div>

										<% if(!item.unlocked){ %>
											<div class="flex flex-row gap-1 items-center text-muted-foreground text-sm truncate">
												<span>Unlocked at</span>
												<div class="flex flex-row gap-1 items-center">
													<%- include('../components/icon.ejs', {
														icon: 'diamond',
														className: 'text-primary size-4'
													}); %>

													<span class="font-bold"><%= item.required %></span>
												</div>
												<span>deposited</span>
											</div>
										<% } %>
									</div>

									<% if(item.unlocked){ %>
										<div class="text-warning font-bold uppercase">Unlocked</div>
									<% } else { %>
										<%- include('../components/icon.ejs', {
											icon: 'lock',
											className: 'text-muted-foreground size-3.5'
										}); %>
									<% } %>
								</div>
							</div>

							<div class="flex flex-col gap-4">
								<div class="text-muted-foreground font-bold">Advantages</div>

								<div class="flex flex-col gap-2">
									<% Object.keys(item.earnings).forEach(function(earning){ %>
										<div><span class="font-bold"><%= item.earnings[earning] %>%</span> earnings of <span class="font-bold"><%= earning %></span></div>
									<% }); %>
								</div>
							</div>
						</div>
					<% }); %>
				</div>
			</div>
			<div class="modal-footer text-center">
				<button type="button" class="button button-hover button-primary shadow-2" data-modal="hide">Close</button>
			</div>
		</div>
	</div>
</div>
<% } %>

