<div class="flex flex-col gap-4">
	<div class="flex flex-col gap-4">
        <div class="flex flex-col gap-2">
            <div class="flex flex-col gap-4 bg-card bg-opacity-50 rounded-2 border-2 border-card pt-8 pb-4 px-4">
                <div class="flex flex-col gap-2 items-center">
                    <div class="avatar-field tier-<%= response.account.user.level.tier %>">
                        <img class="avatar size-32 rounded-full" src="<%= response.account.user.avatar %>">
                    </div>

                    <div class="flex justify-center gap-2 font-bold text-xl">
                        <div class="capitalize chat-link-<%= response.account.user.rank %>"><%= response.account.user.rank %></div>

                        <div class="truncate"><%= response.account.user.name %></div>
                    </div>

                    <div class="level-bar flex items-center gap-1">
                        <div class="font-bold">Lvl. <%= Math.min(response.account.user.level.level + 1, 100) - 1 %></div>

                        <div class="progress-container rounded-1">
                            <% var style = 'style="width: ' + response.account.user.level.progress + '%;"'; %>

                            <div class="progress-bar transition duration-200 ease-linear rounded-1" <%- style %>></div>
                            <div class="progress-content flex flex-row justify-center items-center gap-1 font-bold">
                                <span><%= response.account.user.level.have %></span>
                                <span>/</span>
                                <span><%= response.account.user.level.next %></span>
                            </div>
                        </div>

                        <div class="font-bold"><%= Math.min(response.account.user.level.level + 1, 100) %></div>
                    </div>
                </div>

                <div class="flex flex-row max-md:flex-col gap-2 items-center justify-between">
                    <div class="text-muted-foreground">Member since <%= response.account.user.created %></div>
                    <div><span class="text-muted-foreground">User ID:</span> <%= response.account.user.userid %></div>
                </div>
            </div>

            <div class="flex flex-row max-md:flex-col gap-2">
                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Deposited</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.deposited %></span>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Withdrawn</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.withdrawn %></span>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Wagered</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.wagered %></span>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Profit</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.profit %></span>
                    </div>
                </div>
            </div>
        </div>

        <%- include('./components/tabsMenu.ejs', {
            type: 'top',
            items: [
                {
                    active: true,
                    label: 'Settings',
                    href: '/account/settings'
                },
                {
                    active: false,
                    label: 'Balance History',
                    href: '/account/deposits'
                },
                {
                    active: false,
                    label: 'Games History',
                    href: '/account/games'
                },
                {
                    active: false,
                    label: 'Transactions History',
                    href: '/account/transactions'
                },
                {
                    active: false,
                    label: 'Self Exclusion',
                    href: '/account/exclusion'
                },
                {
                    active: false,
                    label: 'Security',
                    href: '/account/security'
                }
            ]
        }); %>

        <div class="flex flex-row max-md:flex-col gap-2">

            <div class="flex flex-col gap-4 w-full">
                <div class="flex flex-row max-md:flex-col gap-2 w-full">
                    <label class="flex flex-col items-start gap-2 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full pointer">
                        <div class="flex flex-row items-center justify-between gap-2 w-full">
                            <div class="text-left font-bold text-base">Sounds</div>

                            <%- include('./components/inputs/switchField.ejs', {
                                className: 'change-setting',
                                attributes: [
                                    { name: 'data-setting', value: 'sounds' }
                                ]
                            }); %>
                        </div>

                        <div class="text-sm text-muted-foreground">If this is enabled, the game sounds will be active.</div>
                    </label>

                    <label class="flex flex-col items-start gap-4 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full pointer">
                        <div class="flex flex-row items-center justify-between gap-2 w-full">
                            <div class="text-left font-bold text-base">Anonymous</div>

                            <%- include('./components/inputs/switchField.ejs', {
                                className: 'change-setting',
                                attributes: [
                                    { name: 'data-setting', value: 'anonymous' }
                                ]
                            }); %>
                        </div>

                        <div class="text-sm text-muted-foreground">If this is enabled, your profile name and avatar will be anonymously.</div>
                    </label>

                    <label class="flex flex-col items-start gap-4 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full pointer">
                        <div class="flex flex-row items-center justify-between gap-2 w-full">
                            <div class="text-left font-bold text-base">Private Mode</div>

                            <%- include('./components/inputs/switchField.ejs', {
                                className: 'change-setting',
                                attributes: [
                                    { name: 'data-setting', value: 'private' }
                                ]
                            }); %>
                        </div>

                        <div class="text-sm text-muted-foreground">If this is enabled, your profile will be private.</div>
                    </label>
                </div>

                <div class="flex flex-col items-start gap-2">
                    <div class="text-left text-base">Linked Accounts</div>

                    <div class="flex flex-row flex-wrap gap-1">

                        <% if(!response.account.settings.links.google.linked){ %>
                            <a class="flex-1 <% if(!response.account.settings.links.google.enable){ %>disabled<% } %>" href="/auth/google?link=true&returnUrl=/<%= app.paths.join('/') %>">
                                <button class="button button-hover button-primary shadow-2 w-full">Link with Google</button>
                            </a>
                        <% } else { %>
                            <button class="button button-hover button-primary shadow-2 disabled flex-1">Linked with Google</button>
                        <% } %>

                        <% if(!response.account.settings.links.discord.linked){ %>
                            <a class="flex-1 <% if(!response.account.settings.links.discord.enable){ %>disabled<% } %>" href="/auth/discord?link=true&returnUrl=/<%= app.paths.join('/') %>">
                                <button class="button button-hover button-primary shadow-2 w-full">Link with Discord</button>
                            </a>
                        <% } else { %>
                            <button class="button button-hover button-primary shadow-2 disabled flex-1">Linked with Discord</button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>