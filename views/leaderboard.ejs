<div class="table-container">
	<div class="table-header">
		<div class="table-row">
			<div class="table-column text-left">Rank</div>
			<div class="table-column text-left">User</div>
			<div class="table-column text-left">Games played</div>
			<div class="table-column text-left">Total played</div>
			<div class="table-column text-right">Total winnings</div>
		</div>
	</div>

	<div class="table-body">
		<% if(response.leaderboard.length > 0){ %>
            <% response.leaderboard.forEach(function(item, index){ %>
                <%- include('./components/tableLeaderboardRow.ejs', {
					...item,
					rank: index + 1
				}); %>
            <% }); %>
		<% } else { %>
			<%- include('./components/emptyTable.ejs', {
				title: 'No data found'
			}); %>
		<% } %>
	</div>
</div>