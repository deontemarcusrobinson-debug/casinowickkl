<div class="flex flex-col gap-2">
	<div class="flex flex-col gap-4">
        <div class="flex flex-col gap-2">
            <div class="flex flex-col gap-4 bg-card bg-opacity-50 rounded-2 border-2 border-card pt-8 pb-4 px-4">
                <div class="flex flex-col gap-2 items-center">
                    <div class="avatar-field tier-<%= response.account.user.level.tier %>">
                        <img class="avatar size-32 rounded-full" src="<%= response.account.user.avatar %>">
                    </div>

                    <div class="flex justify-center gap-2 font-bold text-xl">
                        <div class="capitalize chat-link-<%= response.account.user.rank %>"><%= response.account.user.rank %></div>

                        <div class="truncate"><%= response.account.user.name %></div>
                    </div>

                    <div class="level-bar flex items-center gap-1">
                        <div class="font-bold">Lvl. <%= Math.min(response.account.user.level.level + 1, 100) - 1 %></div>

                        <div class="progress-container rounded-1">
                            <% var style = 'style="width: ' + response.account.user.level.progress + '%;"'; %>

                            <div class="progress-bar transition duration-200 ease-linear rounded-1" <%- style %>></div>
                            <div class="progress-content flex flex-row justify-center items-center gap-1 font-bold">
                                <span><%= response.account.user.level.have %></span>
                                <span>/</span>
                                <span><%= response.account.user.level.next %></span>
                            </div>
                        </div>

                        <div class="font-bold"><%= Math.min(response.account.user.level.level + 1, 100) %></div>
                    </div>
                </div>

                <div class="flex flex-row max-md:flex-col gap-2 items-center justify-between">
                    <div class="text-muted-foreground">Member since <%= response.account.user.created %></div>
                    <div><span class="text-muted-foreground">User ID:</span> <%= response.account.user.userid %></div>
                </div>
            </div>

            <div class="flex flex-row max-md:flex-col gap-2">
                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Deposited</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.deposited %></span>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Withdrawn</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.withdrawn %></span>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Wagered</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.wagered %></span>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-1 bg-card bg-opacity-50 rounded-2 border-2 border-card p-4 w-full">
                    <div class="text-muted-foreground font-bold">Profit</div>
                    <div class="flex flex-row items-center justify-center gap-1 text-primary">
                        <%- include('./components/icon.ejs', {
                            icon: 'diamond',
                            className: 'size-5'
                        }); %>

                        <span class="text-xl"><%= response.account.stats.profit %></span>
                    </div>
                </div>
            </div>
        </div>

        <%- include('./components/tabsMenu.ejs', {
            type: 'top',
            items: [
                {
                    active: false,
                    label: 'Settings',
                    href: '/account/settings'
                },
                {
                    active: false,
                    label: 'Balance History',
                    href: '/account/deposits'
                },
                {
                    active: false,
                    label: 'Games History',
                    href: '/account/games'
                },
                {
                    active: false,
                    label: 'Transactions History',
                    href: '/account/transactions'
                },
                {
                    active: true,
                    label: 'Self Exclusion',
                    href: '/account/exclusion'
                },
                {
                    active: false,
                    label: 'Security',
                    href: '/account/security'
                }
            ]
        }); %>

        <div class="flex flex-col items-start gap-4">
                <div class="flex flex-col gap-2">
                <div class="text-left font-bold text-base">Self Exclusion</div>

                <div class="flex flex-col gap-1">
                    <div class="text-muted-foreground">If enabled, you won't be able to bet, claim rewards, join on rain event, send coins or deposit anything until the restriction expires. Withdraws and chat privileges will remain active. Use it if you'd like to take a break from playing for an extended period. For custom restrictions, you can always contact us. During this time, we will NOT remove your restrictions for ANY reason, even if you change your mind.</div>
                    <div class="text-muted-foreground"><% if(response.account.exclusion.active) { %><span class="text-danger">Self Exclusion Active - Expires <%= response.account.exclusion.expire %></span><% } else { %><span class="text-success">Self Exclusion Inactive</span><% } %></div>
                </div>
            </div>

            <div class="flex flex-row gap-1">
                <button class="button button-hover button-primary shadow-2" id="self_exclusion_day">24 hours</button>
                <button class="button button-hover button-primary shadow-2" id="self_exclusion_week">7 days</button>
                <button class="button button-hover button-primary shadow-2" id="self_exclusion_month">30 days</button>
            </div>
        </div>
    </div>
</div>