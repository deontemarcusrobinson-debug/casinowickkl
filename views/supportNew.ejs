<div class="flex flex-col gap-4">
    <div class="flex flex-row justify-between items-center gap-2">
        <div class="flex flex-col gap-1">
            <div class="text-xl font-bold">Submit support request</div>

            <div class="text-xs text-muted-foreground">Submit a request for help or report an issue to our support team. Provide details about your issue so our team can assist you as quickly as possible.</div>
        </div>

        <a href="/support/requests">
            <button class="button button-hover button-danger shadow-2">My requests</button>
        </a>
    </div>

    <div class="flex flex-col gap-4 items-start">
        <div class="flex flex-row max-md:flex-col gap-1 w-full">
            <%- include('./components/inputs/inputGroup.ejs', {
                type: 'text',
                label: 'Subject',
                id: 'support_subject',
                errors: [ 'required', 'minimum_6_characters' ]
            }); %>

            <div class="flex flex-row gap-1">
                <%- include('./components/inputs/selectField.ejs', {
                    type: 'bottom',
                    label: 'Department',
                    id: 'support_department',
                    items: [
                        { name: 'General / Others', value: 0 },
                        { name: 'Bug report', value: 1 },
                        { name: 'Trade offer issue', value: 2 },
                        { name: 'Improvements / Ideas', value: 3 },
                        { name: 'Marketing / Partnership', value: 4 },
                        { name: 'Ranking up', value: 5 }
                    ]
                }); %>
            </div>
        </div>

        <%- include('./components/inputs/textareaField.ejs', {
            label: 'Message',
            id: 'support_message',
            errors: [ 'required', 'minimum_10_characters' ]
        }); %>

        <button class="button button-hover button-primary shadow-2 large" id="support_create">Submit request</button>
    </div>
</div>