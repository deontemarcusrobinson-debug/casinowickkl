<div class="w-full text-center font-bold text-xl">Verify Your Identity</div>

<div class="text-muted-foreground">Please enter your password to continue. This step is required to confirm your identity and keep your account secure.</div>

<div class="flex flex-col gap-4">
    <form class="form_auth" autocomplete="off" method="POST" action="/auth/authorize/account">
        <div class="flex flex-col items-center gap-4">
            <%- include('../components/inputs/inputGroup.ejs', {
                type: 'password',
                label: 'Password',
                attributes: [
                    { name: 'name', value: 'password' }
                ],
                errors: [ 'required', 'password' ]
            }); %>

            <button type="submit" class="button button-hover button-primary shadow-2">Submit</button>
        </div>
    </form>
</div>